# ============================================
# Yacht Tracker - Environment Variables Template
# ============================================
# Copy to .env and fill in your values
# ============================================

# ----------------------------------------
# Z.ai API Settings (AI Summaries)
# ----------------------------------------
# Get your API key from: https://z.ai/
ZAI_API_KEY=your_api_key_here
ZAI_MODEL=glm-5.1
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# ----------------------------------------
# Neo4j Database Connection
# ----------------------------------------
# Get these from your Neo4j Aura instance: https://neo4j.com/aura/
NEO4J_URI=bolt://your_instance.databases.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# ----------------------------------------
# Cron Job Secret
# ----------------------------------------
# Generate a random string for cron authentication
# Example: openssl rand -hex 32
CRON_SECRET=your_random_secret